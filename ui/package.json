{
  "engines": {
    "node": "~24"
  },
  "scripts": {
    "start": "vite",
    "build": "i18n-compile i18n build/i18n && cp -u i18n/* build/i18n && vite build",
    "preview": "vite preview",
    "check": "svelte-check --diagnostic-sources js,svelte",
    "check:vite": "npm run check || true",
    "check:dev": "npm run check -- --watch",
    "test": "vitest run",
    "test:dev": "vitest watch"
  },
  "browserslist": [
    "> 0.5%",
    "not dead"
  ],
  "dependencies": {
    "@codeborne/i18n-json": "^0.3.7",
    "svelte": "^5.36.12",
    "svelte5-router": "^3.0.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.5",
    "@testing-library/svelte": "^5.2.8",
    "@tsconfig/svelte": "^3.0.0",
    "@types/chai": "^4.3.3",
    "@types/mocha": "^10.0.0",
    "@vitest/ui": "^0.34.3",
    "autoprefixer": "^10.4.15",
    "chai": "^4.3.6",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.28",
    "postcss-load-config": "^4.0.1",
    "svelte-check": "^4.3.0",
    "svelte-preprocess": "^5.1.4",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vite-plugin-run": "^0.5.1",
    "vitest": "^3.2.4"
  }
}
